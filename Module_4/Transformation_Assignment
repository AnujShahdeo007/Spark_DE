from pyspark.sql import SparkSession
from pyspark.sql.functions import col, lit, expr, when, coalesce
from pyspark.sql.functions import nvl

spark = SparkSession.builder.appName("ColumnExpressionsPractice").getOrCreate()

data = [
    (1, "Gaurav", 30, 50000, "HR", "Pune"),
    (2, "Priya", 28, None, "IT", "Mumbai"),
    (3, "Rahul", 35, 70000, "HR", None),
    (4, "Sneha", None, 80000, "Finance", "Delhi"),
    (5, "Amit", 40, 90000, "IT", "Pune"),
    (6, "Sonal", 25, 45000, "Admin", "Nagpur"),
    (7, "Arjun", 32, None, "IT", "Bangalore"),
    (8, "Simran", 29, 62000, "Finance", "Mumbai")
]

columns = ["emp_id", "name", "age", "salary", "dept", "city"]

df = spark.createDataFrame(data, columns)

df.show()
df.printSchema()




